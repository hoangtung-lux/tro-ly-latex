[
  {
    "name": "\\documentclass",
    "category": "Cấu trúc tài liệu",
    "description": "Khai báo loại tài liệu LaTeX",
    "syntax": "\\documentclass[options]{class}",
    "example": "\\documentclass[12pt,a4paper]{article}",
    "output": "Thiết lập lớp tài liệu: article, report, book, beamer..."
  },
  {
    "name": "\\usepackage",
    "category": "Cấu trúc tài liệu",
    "description": "Nhập gói lệnh mở rộng",
    "syntax": "\\usepackage[options]{package}",
    "example": "\\usepackage[utf8]{inputenc}",
    "output": "Kích hoạt gói lệnh trong preamble"
  },
  {
    "name": "\\begin",
    "category": "Cấu trúc tài liệu",
    "description": "Bắt đầu một môi trường LaTeX",
    "syntax": "\\begin{environment}",
    "example": "\\begin{document}",
    "output": "Mở một môi trường như document, equation, itemize..."
  },
  {
    "name": "\\end",
    "category": "Cấu trúc tài liệu",
    "description": "Kết thúc một môi trường LaTeX",
    "syntax": "\\end{environment}",
    "example": "\\end{document}",
    "output": "Đóng môi trường tương ứng với \\begin"
  },
  {
    "name": "\\title",
    "category": "Cấu trúc tài liệu",
    "description": "Đặt tiêu đề tài liệu",
    "syntax": "\\title{Tiêu đề}",
    "example": "\\title{Báo cáo Toán học}",
    "output": "Định nghĩa tiêu đề, dùng với \\maketitle"
  },
  {
    "name": "\\author",
    "category": "Cấu trúc tài liệu",
    "description": "Đặt tên tác giả",
    "syntax": "\\author{Tên tác giả}",
    "example": "\\author{Nguyễn Văn A}",
    "output": "Định nghĩa tên tác giả, dùng với \\maketitle"
  },
  {
    "name": "\\maketitle",
    "category": "Cấu trúc tài liệu",
    "description": "Tạo trang tiêu đề",
    "syntax": "\\maketitle",
    "example": "\\maketitle",
    "output": "In tiêu đề, tác giả, ngày tháng ra tài liệu"
  },
  {
    "name": "\\section",
    "category": "Cấu trúc tài liệu",
    "description": "Tạo mục cấp 1",
    "syntax": "\\section{Tên mục}",
    "example": "\\section{Giới thiệu}",
    "output": "Tạo tiêu đề mục lớn, tự đánh số"
  },
  {
    "name": "\\subsection",
    "category": "Cấu trúc tài liệu",
    "description": "Tạo mục cấp 2",
    "syntax": "\\subsection{Tên mục}",
    "example": "\\subsection{Phương trình bậc hai}",
    "output": "Tạo tiêu đề mục con, tự đánh số"
  },
  {
    "name": "\\subsubsection",
    "category": "Cấu trúc tài liệu",
    "description": "Tạo mục cấp 3",
    "syntax": "\\subsubsection{Tên mục}",
    "example": "\\subsubsection{Công thức nghiệm}",
    "output": "Tạo tiêu đề mục nhỏ nhất"
  },
  {
    "name": "\\tableofcontents",
    "category": "Cấu trúc tài liệu",
    "description": "Tạo mục lục tự động",
    "syntax": "\\tableofcontents",
    "example": "\\tableofcontents",
    "output": "In mục lục với số trang tự động"
  },
  {
    "name": "\\frac",
    "category": "Toán học",
    "description": "Viết phân số",
    "syntax": "\\frac{tử số}{mẫu số}",
    "example": "\\frac{1}{2}",
    "output": "½ — phân số với tử và mẫu"
  },
  {
    "name": "\\sqrt",
    "category": "Toán học",
    "description": "Viết căn bậc hai (hoặc bậc n)",
    "syntax": "\\sqrt[n]{biểu thức}",
    "example": "\\sqrt{x^2 + y^2}",
    "output": "√(x² + y²)"
  },
  {
    "name": "\\sum",
    "category": "Toán học",
    "description": "Ký hiệu tổng sigma",
    "syntax": "\\sum_{dưới}^{trên}",
    "example": "\\sum_{i=1}^{n} i",
    "output": "Σ từ i=1 đến n của i"
  },
  {
    "name": "\\int",
    "category": "Toán học",
    "description": "Ký hiệu tích phân",
    "syntax": "\\int_{dưới}^{trên}",
    "example": "\\int_{0}^{1} x\\,dx",
    "output": "∫ từ 0 đến 1 của x dx"
  },
  {
    "name": "\\lim",
    "category": "Toán học",
    "description": "Ký hiệu giới hạn",
    "syntax": "\\lim_{biến \\to giá trị}",
    "example": "\\lim_{x \\to 0} \\frac{\\sin x}{x}",
    "output": "lim(x→0) sin(x)/x"
  },
  {
    "name": "\\infty",
    "category": "Toán học",
    "description": "Ký hiệu vô cùng",
    "syntax": "\\infty",
    "example": "\\lim_{n \\to \\infty}",
    "output": "∞"
  },
  {
    "name": "\\alpha",
    "category": "Toán học",
    "description": "Chữ Hy Lạp alpha",
    "syntax": "\\alpha",
    "example": "\\alpha + \\beta = \\gamma",
    "output": "α"
  },
  {
    "name": "\\beta",
    "category": "Toán học",
    "description": "Chữ Hy Lạp beta",
    "syntax": "\\beta",
    "example": "\\beta",
    "output": "β"
  },
  {
    "name": "\\gamma",
    "category": "Toán học",
    "description": "Chữ Hy Lạp gamma",
    "syntax": "\\gamma",
    "example": "\\Gamma(n) = (n-1)!",
    "output": "γ (viết hoa: Γ)"
  },
  {
    "name": "\\pi",
    "category": "Toán học",
    "description": "Hằng số Pi",
    "syntax": "\\pi",
    "example": "A = \\pi r^2",
    "output": "π ≈ 3.14159..."
  },
  {
    "name": "\\theta",
    "category": "Toán học",
    "description": "Chữ Hy Lạp theta",
    "syntax": "\\theta",
    "example": "\\sin(\\theta)",
    "output": "θ"
  },
  {
    "name": "\\Delta",
    "category": "Toán học",
    "description": "Chữ Delta hoa (delta)",
    "syntax": "\\Delta",
    "example": "\\Delta = b^2 - 4ac",
    "output": "Δ"
  },
  {
    "name": "\\leq",
    "category": "Toán học",
    "description": "Nhỏ hơn hoặc bằng",
    "syntax": "\\leq",
    "example": "x \\leq y",
    "output": "≤"
  },
  {
    "name": "\\geq",
    "category": "Toán học",
    "description": "Lớn hơn hoặc bằng",
    "syntax": "\\geq",
    "example": "x \\geq 0",
    "output": "≥"
  },
  {
    "name": "\\neq",
    "category": "Toán học",
    "description": "Khác (không bằng)",
    "syntax": "\\neq",
    "example": "x \\neq 0",
    "output": "≠"
  },
  {
    "name": "\\approx",
    "category": "Toán học",
    "description": "Xấp xỉ bằng",
    "syntax": "\\approx",
    "example": "\\pi \\approx 3.14",
    "output": "≈"
  },
  {
    "name": "\\times",
    "category": "Toán học",
    "description": "Phép nhân (dấu ×)",
    "syntax": "\\times",
    "example": "3 \\times 4 = 12",
    "output": "×"
  },
  {
    "name": "\\cdot",
    "category": "Toán học",
    "description": "Dấu chấm nhân",
    "syntax": "\\cdot",
    "example": "a \\cdot b",
    "output": "·"
  },
  {
    "name": "\\pm",
    "category": "Toán học",
    "description": "Cộng trừ",
    "syntax": "\\pm",
    "example": "x = \\pm 5",
    "output": "±"
  },
  {
    "name": "\\in",
    "category": "Toán học",
    "description": "Thuộc về (ký hiệu tập hợp)",
    "syntax": "\\in",
    "example": "x \\in \\mathbb{R}",
    "output": "∈"
  },
  {
    "name": "\\mathbb",
    "category": "Toán học",
    "description": "Chữ blackboard bold (tập hợp số)",
    "syntax": "\\mathbb{ký tự}",
    "example": "\\mathbb{R}, \\mathbb{N}, \\mathbb{Z}",
    "output": "ℝ, ℕ, ℤ — tập số thực, tự nhiên, nguyên"
  },
  {
    "name": "\\vec",
    "category": "Toán học",
    "description": "Ký hiệu vectơ",
    "syntax": "\\vec{tên}",
    "example": "\\vec{v} = (1, 2, 3)",
    "output": "v⃗"
  },
  {
    "name": "\\hat",
    "category": "Toán học",
    "description": "Dấu mũ trên ký tự",
    "syntax": "\\hat{ký tự}",
    "example": "\\hat{n}",
    "output": "n̂"
  },
  {
    "name": "\\overline",
    "category": "Toán học",
    "description": "Gạch trên biểu thức",
    "syntax": "\\overline{biểu thức}",
    "example": "\\overline{AB}",
    "output": "AB̄ — thanh trên"
  },
  {
    "name": "\\underbrace",
    "category": "Toán học",
    "description": "Dấu ngoặc dưới có chú thích",
    "syntax": "\\underbrace{biểu thức}_{chú thích}",
    "example": "\\underbrace{x + y}_{\\text{tổng}}",
    "output": "(x + y) với nhãn bên dưới"
  },
  {
    "name": "\\textbf",
    "category": "Định dạng văn bản",
    "description": "Chữ in đậm",
    "syntax": "\\textbf{văn bản}",
    "example": "\\textbf{Quan trọng}",
    "output": "**Quan trọng**"
  },
  {
    "name": "\\textit",
    "category": "Định dạng văn bản",
    "description": "Chữ in nghiêng",
    "syntax": "\\textit{văn bản}",
    "example": "\\textit{chú ý}",
    "output": "*chú ý*"
  },
  {
    "name": "\\underline",
    "category": "Định dạng văn bản",
    "description": "Gạch chân văn bản",
    "syntax": "\\underline{văn bản}",
    "example": "\\underline{gạch chân}",
    "output": "<u>gạch chân</u>"
  },
  {
    "name": "\\textcolor",
    "category": "Định dạng văn bản",
    "description": "Đổi màu chữ (cần gói xcolor)",
    "syntax": "\\textcolor{màu}{văn bản}",
    "example": "\\textcolor{red}{chú ý}",
    "output": "chữ màu đỏ"
  },
  {
    "name": "\\emph",
    "category": "Định dạng văn bản",
    "description": "Nhấn mạnh (thường là nghiêng)",
    "syntax": "\\emph{văn bản}",
    "example": "\\emph{từ khoá}",
    "output": "*từ khoá* — nghiêng hoặc đứng tuỳ ngữ cảnh"
  },
  {
    "name": "\\newline",
    "category": "Định dạng văn bản",
    "description": "Xuống dòng trong đoạn văn",
    "syntax": "\\newline hoặc \\\\",
    "example": "Dòng 1 \\\\ Dòng 2",
    "output": "Xuống dòng mềm"
  },
  {
    "name": "\\newpage",
    "category": "Định dạng văn bản",
    "description": "Sang trang mới",
    "syntax": "\\newpage",
    "example": "\\newpage",
    "output": "Bắt đầu trang mới"
  },
  {
    "name": "\\hspace",
    "category": "Định dạng văn bản",
    "description": "Khoảng cách ngang",
    "syntax": "\\hspace{độ rộng}",
    "example": "\\hspace{1cm}",
    "output": "Khoảng cách ngang 1cm"
  },
  {
    "name": "\\vspace",
    "category": "Định dạng văn bản",
    "description": "Khoảng cách dọc",
    "syntax": "\\vspace{chiều cao}",
    "example": "\\vspace{0.5cm}",
    "output": "Khoảng cách dọc 0.5cm"
  },
  {
    "name": "\\itemize",
    "category": "Danh sách",
    "description": "Danh sách dạng gạch đầu dòng",
    "syntax": "\\begin{itemize}\n  \\item ...\n\\end{itemize}",
    "example": "\\begin{itemize}\n  \\item Mục 1\n  \\item Mục 2\n\\end{itemize}",
    "output": "• Mục 1\n• Mục 2"
  },
  {
    "name": "\\enumerate",
    "category": "Danh sách",
    "description": "Danh sách đánh số thứ tự",
    "syntax": "\\begin{enumerate}\n  \\item ...\n\\end{enumerate}",
    "example": "\\begin{enumerate}\n  \\item Bước 1\n  \\item Bước 2\n\\end{enumerate}",
    "output": "1. Bước 1\n2. Bước 2"
  },
  {
    "name": "\\item",
    "category": "Danh sách",
    "description": "Phần tử trong danh sách",
    "syntax": "\\item[ký hiệu tùy chọn] nội dung",
    "example": "\\item Nội dung mục",
    "output": "Một mục trong itemize hoặc enumerate"
  },
  {
    "name": "\\tabular",
    "category": "Bảng biểu",
    "description": "Tạo bảng dữ liệu",
    "syntax": "\\begin{tabular}{cột}\n  ...\n\\end{tabular}",
    "example": "\\begin{tabular}{|c|c|}\n  \\hline\n  A & B \\\\\n  \\hline\n\\end{tabular}",
    "output": "Bảng 2 cột có đường kẻ"
  },
  {
    "name": "\\hline",
    "category": "Bảng biểu",
    "description": "Kẻ đường ngang trong bảng",
    "syntax": "\\hline",
    "example": "\\hline",
    "output": "Đường kẻ ngang trong bảng"
  },
  {
    "name": "\\multicolumn",
    "category": "Bảng biểu",
    "description": "Gộp nhiều cột trong bảng",
    "syntax": "\\multicolumn{số cột}{căn lề}{nội dung}",
    "example": "\\multicolumn{2}{c}{Tiêu đề gộp}",
    "output": "Ô bảng gộp 2 cột, căn giữa"
  },
  {
    "name": "\\includegraphics",
    "category": "Hình ảnh",
    "description": "Chèn hình ảnh vào tài liệu",
    "syntax": "\\includegraphics[options]{filename}",
    "example": "\\includegraphics[width=0.8\\textwidth]{hinh.png}",
    "output": "Chèn hình với chiều rộng 80% trang"
  },
  {
    "name": "\\caption",
    "category": "Hình ảnh",
    "description": "Chú thích cho hình/bảng",
    "syntax": "\\caption{Chú thích}",
    "example": "\\caption{Đồ thị hàm số}",
    "output": "Hình 1: Đồ thị hàm số"
  },
  {
    "name": "\\label",
    "category": "Tham chiếu",
    "description": "Gán nhãn để tham chiếu",
    "syntax": "\\label{tên nhãn}",
    "example": "\\label{fig:dothi}",
    "output": "Gán nhãn cho hình, bảng, phương trình..."
  },
  {
    "name": "\\ref",
    "category": "Tham chiếu",
    "description": "Tham chiếu đến nhãn",
    "syntax": "\\ref{tên nhãn}",
    "example": "xem Hình \\ref{fig:dothi}",
    "output": "xem Hình 1 — tự cập nhật số"
  },
  {
    "name": "\\footnote",
    "category": "Tham chiếu",
    "description": "Tạo chú thích cuối trang",
    "syntax": "\\footnote{nội dung}",
    "example": "Khái niệm này\\footnote{Xem thêm tài liệu X}",
    "output": "Số ¹ trong văn bản, nội dung ở cuối trang"
  },
  {
    "name": "\\cite",
    "category": "Tham chiếu",
    "description": "Trích dẫn tài liệu tham khảo",
    "syntax": "\\cite{bibtex_key}",
    "example": "theo nghiên cứu \\cite{nguyen2020}",
    "output": "[1] hoặc [Nguyen2020] tuỳ style"
  },
  {
    "name": "\\%",
    "category": "Ký hiệu đặc biệt",
    "description": "Ký hiệu phần trăm",
    "syntax": "\\%",
    "example": "đạt 95\\%",
    "output": "95%"
  },
  {
    "name": "\\$",
    "category": "Ký hiệu đặc biệt",
    "description": "Ký hiệu đô la",
    "syntax": "\\$",
    "example": "giá \\$100",
    "output": "$100"
  },
  {
    "name": "\\&",
    "category": "Ký hiệu đặc biệt",
    "description": "Ký hiệu và (&)",
    "syntax": "\\&",
    "example": "Tom \\& Jerry",
    "output": "Tom & Jerry"
  },
  {
    "name": "\\ldots",
    "category": "Ký hiệu đặc biệt",
    "description": "Dấu ba chấm ngang",
    "syntax": "\\ldots",
    "example": "1, 2, 3, \\ldots",
    "output": "1, 2, 3, ..."
  },
  {
    "name": "\\cdots",
    "category": "Toán học",
    "description": "Dấu ba chấm ở giữa (dùng trong toán)",
    "syntax": "\\cdots",
    "example": "a_1 + a_2 + \\cdots + a_n",
    "output": "a₁ + a₂ + ··· + aₙ"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Môi trường TikZ",
    "syntax": "\\begin{tikzpicture}\n  [Nội dung vẽ]\n\\end{tikzpicture}",
    "description": "Bắt đầu vùng vẽ hình học chuyên nghiệp.",
    "example": "\\begin{tikzpicture}\n  \\draw (0,0) -- (4,0);\n\\end{tikzpicture}",
    "output": "Vẽ một đường thẳng từ (0,0) đến (4,0)"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Đường thẳng / Đoạn thẳng",
    "syntax": "\\draw (x1,y1) -- (x2,y2);",
    "description": "Vẽ đoạn thẳng nối hai điểm toạ độ.",
    "example": "\\draw (0,0) -- (2,3);",
    "output": "Đoạn thẳng nối (0,0) và (2,3)"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Đường tròn",
    "syntax": "\\draw (x,y) circle (bán_kính);",
    "description": "Vẽ đường tròn tâm (x,y) với bán kính xác định.",
    "example": "\\draw (0,0) circle (2cm);",
    "output": "Đường tròn tâm O bán kính 2cm"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Hình chữ nhật",
    "syntax": "\\draw (x1,y1) rectangle (x2,y2);",
    "description": "Vẽ hình chữ nhật xác định bởi hai góc đối diện.",
    "example": "\\draw (0,0) rectangle (4,2);",
    "output": "Hình chữ nhật rộng 4 cao 2"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Tam giác cơ bản",
    "syntax": "\\draw (0,0) -- (4,0) -- (2,3) -- cycle;",
    "description": "Vẽ tam giác bằng cách nối 3 điểm và khép kín (cycle).",
    "example": "\\draw (0,0) -- (4,0) -- (2,3) -- cycle;",
    "output": "Hình tam giác"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Điểm và Nhãn (Node)",
    "syntax": "\\filldraw (x,y) circle (2pt) node[anchor] {Tên};",
    "description": "Vẽ một điểm đậm và viết tên nhãn bên cạnh.",
    "example": "\\filldraw (0,0) circle (2pt) node[below] {A};",
    "output": "Điểm A với chấm tròn"
  },
  {
    "category": "Hình học (TikZ)",
    "name": "Hệ trục toạ độ",
    "syntax": "\\draw[->] (-1,0) -- (5,0) node[right] {$x$};\n\\draw[->] (0,-1) -- (0,4) node[above] {$y$};",
    "description": "Vẽ hai trục Ox, Oy có mũi tên và nhãn.",
    "example": "\\draw[->] (-1,0) -- (3,0) node[right] {$x$};\n\\draw[->] (0,-1) -- (0,3) node[above] {$y$};",
    "output": "Trục tọa độ Oxy"
  }
]
